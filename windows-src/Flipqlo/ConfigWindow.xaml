<Window x:Class="Flipqlo.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flipqlo — Screen Saver Settings"
        Width="420" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="#1E1E1E">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Flipqlo Settings"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="#D8D8D8"/>

        <!-- 24-hour toggle -->
        <CheckBox Grid.Row="2"
                  x:Name="chk24Hour"
                  Content="Use 24-hour format"
                  Foreground="#CCCCCC" FontSize="14"
                  Checked="OnOptionChanged"
                  Unchecked="OnOptionChanged"
                  Margin="0,0,0,10"/>

        <!-- Show seconds toggle -->
        <CheckBox Grid.Row="3"
                  x:Name="chkSeconds"
                  Content="Show seconds"
                  Foreground="#CCCCCC" FontSize="14"
                  Checked="OnOptionChanged"
                  Unchecked="OnOptionChanged"
                  Margin="0,0,0,10"/>

        <!-- Primary screen only -->
        <CheckBox Grid.Row="4"
                  x:Name="chkPrimary"
                  Content="Primary screen only"
                  Foreground="#CCCCCC" FontSize="14"
                  Checked="OnOptionChanged"
                  Unchecked="OnOptionChanged"
                  Margin="0,0,0,10"/>

        <!-- Scale section header -->
        <TextBlock Grid.Row="6"
                   Text="Size &amp; Scale"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="#D8D8D8"
                   Margin="0,0,0,8"/>

        <!-- Horizontal Width slider -->
        <Grid Grid.Row="7" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Horizontal Width"
                       Foreground="#AAAAAA" FontSize="13" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" x:Name="sliderHorizontal"
                    Minimum="50" Maximum="200" TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="OnSliderChanged"
                    VerticalAlignment="Center" Margin="8,0"/>
            <TextBlock Grid.Column="2" x:Name="lblHorizontal"
                       Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Vertical Height slider -->
        <Grid Grid.Row="8" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Vertical Height"
                       Foreground="#AAAAAA" FontSize="13" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" x:Name="sliderVertical"
                    Minimum="50" Maximum="200" TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="OnSliderChanged"
                    VerticalAlignment="Center" Margin="8,0"/>
            <TextBlock Grid.Column="2" x:Name="lblVertical"
                       Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Overall Scale slider -->
        <Grid Grid.Row="9" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Overall Scale"
                       Foreground="#AAAAAA" FontSize="13" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" x:Name="sliderOverall"
                    Minimum="50" Maximum="200" TickFrequency="5"
                    IsSnapToTickEnabled="True"
                    ValueChanged="OnSliderChanged"
                    VerticalAlignment="Center" Margin="8,0"/>
            <TextBlock Grid.Column="2" x:Name="lblOverall"
                       Foreground="#CCCCCC" FontSize="13"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Live preview -->
        <Border Grid.Row="10"
                Margin="0,10,0,16"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#333333"
                Background="#101010"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Live Preview"
                           Foreground="#BDBDBD"
                           FontSize="12"
                           Margin="10,8,10,6"/>

                <Border Grid.Row="1"
                        Margin="10,0,10,10"
                        CornerRadius="6"
                        ClipToBounds="True"
                        Background="#000000">
                    <Border x:Name="previewHost" MinHeight="140"/>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="11" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Reset" Width="80" Margin="0,0,8,0"
                    Click="OnReset"/>
            <Button Content="OK" Width="80" Margin="0,0,8,0"
                    Click="OnOk"/>
            <Button Content="Cancel" Width="80"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
